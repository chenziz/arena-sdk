#!/usr/bin/env bash
# Arena SDK CLI wrapper.
#   ./arena selfplay|eval|pack|submit|comps|access|live|version ...
# Uses the repo .venv if present, else the system python3.
set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
PY="${HERE}/.venv/bin/python"
[ -x "$PY" ] || PY="$(command -v python3)"
exec "$PY" -m arena_sdk "$@"
