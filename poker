#!/usr/bin/env bash
# Branded CLI wrapper — mirrors the Arena Starter Kit's ./pokerkit.
#   ./poker selfplay|eval|pack|submit|comps|live|version ...
# Uses the repo .venv if present, else the system python3.
set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
PY="${HERE}/.venv/bin/python"
[ -x "$PY" ] || PY="$(command -v python3)"
exec "$PY" -m devfun_poker_sdk "$@"
